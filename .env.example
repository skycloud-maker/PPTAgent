# PPTAgent environment variables
# Copy this file to .env and fill in real values.

# Required: OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override the default OpenAI model
OPENAI_MODEL=gpt-5-mini

# Optional: provider selection. Default is "openai".
PPTAGENT_LLM_PROVIDER=openai

# Optional: company-specific template settings
PPTAGENT_COMPANY_NAME=Your Company
PPTAGENT_CONFIDENTIAL_LABEL=Internal Use Only
PPTAGENT_FONT_KO=Malgun Gothic
PPTAGENT_FONT_EN=Arial

# Optional: absolute path to a local company logo image
# Example: C:\Users\name\Pictures\company_logo.png
PPTAGENT_LOGO_PATH=