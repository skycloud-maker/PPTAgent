# PPTAgent environment variables
# Copy this file to .env and fill in real values.

# LLM 제공자 설정
# mock  = API 키 없이 테스트 (기본값)
# openai = 실제 OpenAI API 사용
LLM_PROVIDER=mock

# OpenAI API 키 (LLM_PROVIDER=openai 일 때만 필요)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# 회사 커스터마이징
PPTAGENT_COMPANY_NAME=Your Company
PPTAGENT_CONFIDENTIAL_LABEL=내부 공유용
PPTAGENT_FONT_KO=LG스마트체
PPTAGENT_FONT_EN=Arial Narrow
PPTAGENT_LOGO_PATH=
